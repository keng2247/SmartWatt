# =====================================================
# SmartWatt Backend - Environment Configuration
# =====================================================
# 
# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Never commit .env to version control
#
# =====================================================

# ============================
# Server Configuration
# ============================

# Server host (use 0.0.0.0 to allow external connections)
HOST=0.0.0.0

# Server port
PORT=8000

# Environment mode (development | staging | production)
ENVIRONMENT=development

# Debug mode (true | false) - Disable in production!
DEBUG=true

# ============================
# CORS Configuration
# ============================

# Allowed origins (comma-separated list of URLs)
# Add your frontend URL(s) here
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://smartwatt-frontend.vercel.app

# ============================
# Database Configuration
# ============================

# Supabase Configuration (Optional - for cloud training data storage)
# Sign up at https://supabase.com to get these credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================
# AI/ML Configuration
# ============================

# Model confidence threshold (0.0 - 1.0)
# Predictions below this confidence will trigger warnings
MODEL_CONFIDENCE_THRESHOLD=0.85

# Enable/disable model caching for faster predictions
ENABLE_MODEL_CACHING=true

# Maximum batch size for /predict-all endpoint
MAX_BATCH_SIZE=100

# ============================
# Logging Configuration
# ============================

# Log level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Enable request logging
LOG_REQUESTS=true

# Log file path (leave empty to disable file logging)
LOG_FILE_PATH=logs/smartwatt.log

# ============================
# Security Configuration
# ============================

# API Key for protected endpoints (optional)
# API_KEY=your-secret-api-key-here

# Rate limiting (requests per minute)
RATE_LIMIT=60

# Enable HTTPS redirect in production
FORCE_HTTPS=false

# ============================
# External Services
# ============================

# Weather API (optional - for temperature-based predictions)
# WEATHER_API_KEY=your-openweather-api-key
# WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Notification service (optional)
# EMAIL_SERVICE_API_KEY=your-sendgrid-api-key
# SMS_SERVICE_API_KEY=your-twilio-api-key

# ============================
# Feature Flags
# ============================

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable self-learning system
ENABLE_SELF_LEARNING=true

# Enable anomaly detection
ENABLE_ANOMALY_DETECTION=true

# ============================
# Performance Tuning
# ============================

# Number of worker processes (recommended: number of CPU cores)
WORKERS=4

# Worker timeout in seconds
TIMEOUT=60

# Keep-alive timeout
KEEP_ALIVE=5

# ============================
# Development Only
# ============================

# Enable auto-reload on code changes (development only)
RELOAD=true

# Enable detailed error messages (disable in production)
SHOW_ERROR_DETAILS=true

# =====================================================
# Notes:
# - All values are optional unless marked as required
# - Default values are used if not specified
# - See README.md for detailed configuration guide
# =====================================================
